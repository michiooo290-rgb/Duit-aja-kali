# ====================================
# DUIT TRACKER PRO - Environment Variables
# ====================================
# Copy this file to .env and fill in the values

# Get from: https://supabase.com -> Project Settings -> Database -> Connection string (URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# Replace with a long random string (minimum 32 characters)
# Example: use https://randomkeygen.com
JWT_SECRET=replace_with_a_long_random_secret_string_at_least_32_chars

# Server port (Railway/Render will set this automatically)
PORT=3000

# Default PIN for first login
DEFAULT_PIN=1234
